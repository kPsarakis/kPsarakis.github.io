{% if site.enable_google_analytics %}
  <!--
    Google Analytics, deferred off the critical path. See the
    IIFE below for the rationale and trigger conditions.
  -->
  <script>
    // Lighthouse flagged /gtag/js as ~65 KiB of unused JS on the
    // critical path. Keep the dataLayer/gtag shim defined
    // immediately so inline gtag() calls from page code still queue
    // correctly, but postpone injecting the real gtag/js script
    // until the earliest of: first user interaction, browser-idle,
    // or a 2 s fallback. GA still records the pageview.
    (function () {
      window.dataLayer = window.dataLayer || [];
      window.gtag = function () {
        window.dataLayer.push(arguments);
      };
      gtag('js', new Date());
      gtag('config', '{{ site.google_analytics }}');

      var loaded = false;
      function loadGtag() {
        if (loaded) return;
        loaded = true;
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id={{ site.google_analytics }}';
        document.head.appendChild(s);
      }

      // { once: true, passive: true } prevents scroll-jank and
      // auto-removes the listener after firing.
      var events = ['pointerdown', 'keydown', 'scroll', 'touchstart'];
      events.forEach(function (ev) {
        window.addEventListener(ev, loadGtag, { once: true, passive: true });
      });
      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadGtag, { timeout: 2000 });
      } else {
        setTimeout(loadGtag, 2000);
      }
    })();
  </script>
{% endif %}
{% if site.enable_cronitor_analytics %}
  <!-- Cronitor RUM -->
  <script async src="https://rum.cronitor.io/script.js"></script>
  <script>
    window.cronitor =
      window.cronitor ||
      function () {
        (window.cronitor.q = window.cronitor.q || []).push(arguments);
      };
    cronitor('config', { clientKey: '{{ site.cronitor_analytics }}' });
  </script>
{% endif %}
{% if site.enable_pirsch_analytics %}
  <script
    defer
    src="https://api.pirsch.io/pa.js"
    id="pianjs"
    data-code="{{ site.pirsch_analytics }}"
  ></script>
{% endif %}
{% if site.enable_openpanel_analytics %}
  <script>
    window.op =
      window.op ||
      function (...args) {
        (window.op.q = window.op.q || []).push(args);
      };
    window.op('init', {
      clientId: '{{ site.openpanel_analytics }}',
      trackScreenViews: true,
      trackOutgoingLinks: true,
      trackAttributes: true,
    });
  </script>
  <script src="https://openpanel.dev/op1.js" defer async></script>
{% endif %}
