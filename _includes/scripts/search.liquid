{% if site.search_enabled %}
  {%- comment -%}
    ninja-keys.min.js + its lit/hotkeys-js dependency tree is ~200 KB of
    JS. Most visitors never open the command palette, so we defer loading
    until first activation — either the `/` / ⌘K hotkey, or a click on
    the search button. The `<ninja-keys>` element sits in the DOM as an
    un-upgraded HTMLElement until then; assigning `.data` and classList
    tweaks pre-upgrade are preserved by the custom element upgrade path.

    Also disables ninja-keys' built-in hotkey handler (hotkeys-js under
    the hood). Its default `cmd+k,ctrl+k` is intercepted by browser
    chrome (Firefox focuses the search bar, Chrome the omnibox) — pages
    never see those events. We bind our own capture-phase listener below
    so the handler runs before stylesheet / framework listeners and
    before the browser's legacy quick-find on `/`.
  {%- endcomment -%}
  <ninja-keys hideBreadcrumbs noAutoLoadMdIcons placeholder="Type to start searching" openHotkey=""></ninja-keys>
  <script>
    (function () {
      const ninjaKeys = document.querySelector('ninja-keys');
      if (!ninjaKeys) return;

      // Initial theme sync (re-run on theme toggle is handled in theme.js).
      // classList on a pre-upgrade element survives the upgrade transition.
      if (typeof determineComputedTheme === 'function' && determineComputedTheme() === 'dark') {
        ninjaKeys.classList.add('dark');
      } else {
        ninjaKeys.classList.remove('dark');
      }

      // Lazy import of the ninja-keys web component. Fires at most once;
      // subsequent calls reuse the cached promise.
      const NINJA_KEYS_SRC = {{ '/assets/js/search/ninja-keys.min.js' | relative_url | bust_file_cache | jsonify }};
      let ninjaLoader = null;
      function ensureNinjaKeys() {
        if (ninjaLoader) return ninjaLoader;
        ninjaLoader = import(NINJA_KEYS_SRC)
          .then(function () { return customElements.whenDefined('ninja-keys'); })
          .catch(function (err) {
            // Allow a retry on the next activation rather than getting stuck.
            ninjaLoader = null;
            throw err;
          });
        return ninjaLoader;
      }

      window.openSearchModal = function () {
        // Collapse navbarNav if expanded on mobile, via Bootstrap 5 Collapse API.
        const navbarNav = document.getElementById('navbarNav');
        if (navbarNav && navbarNav.classList.contains('show') && typeof bootstrap !== 'undefined' && bootstrap.Collapse) {
          bootstrap.Collapse.getOrCreateInstance(navbarNav).hide();
        }
        ensureNinjaKeys().then(function () { ninjaKeys.open(); });
      };

      // Skip the hotkey when the user is typing into a form control or
      // a contenteditable region — `/` is a legitimate character there.
      function isTypingTarget(el) {
        if (!el) return false;
        if (el.isContentEditable) return true;
        const tag = el.tagName;
        return tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT';
      }

      // Platform detection via UA-CH when available, falling back to the
      // deprecated navigator.platform. We only need the Mac / non-Mac
      // distinction.
      const isMac =
        (navigator.userAgentData && navigator.userAgentData.platform ? navigator.userAgentData.platform : navigator.platform || '')
          .toUpperCase()
          .indexOf('MAC') >= 0;

      document.addEventListener(
        'keydown',
        function (e) {
          if (e.defaultPrevented) return;
          if (isTypingTarget(e.target)) return;

          const isSearchCombo =
            (isMac && e.metaKey && !e.ctrlKey && !e.altKey && e.key.toLowerCase() === 'k') ||
            (!isMac && e.key === '/' && !e.ctrlKey && !e.metaKey && !e.altKey);

          if (!isSearchCombo) return;

          // preventDefault must run before the browser's default quick-find
          // on `/` (Firefox) or omnibox focus on ⌘K — capture phase gives us
          // the earliest reliable chance.
          e.preventDefault();
          e.stopPropagation();
          window.openSearchModal();
        },
        true
      );
    })();
  </script>
  {%- comment -%}
    The ninja-keys `.data` payload is identical across every page of the
    site, but it used to be rendered inline — so every HTML document shipped
    the same (large) command-palette index. We now emit it once into
    /assets/js/search-data.js and load it here. The query string is pinned
    to site.time so a fresh build gets a fresh URL (and thus a fresh cache
    entry), while within a single build every page reuses the cached copy.
  {%- endcomment -%}
  <script defer src="{{ '/assets/js/search-data.js' | relative_url }}?v={{ site.time | date: '%s' }}"></script>
  <script src="{{ '/assets/js/shortcut-key.js' | relative_url | bust_file_cache }}"></script>
{% endif %}
