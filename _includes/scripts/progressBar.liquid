{% if site.enable_progressbar %}
  <!-- Scrolling Progress Bar -->
  <script type="text/javascript">
    /*
     * This JavaScript code has been adapted from the article
     * https://css-tricks.com/reading-position-indicator/ authored by Pankaj Parashar,
     * published on the website https://css-tricks.com on the 7th of May, 2014.
     * Couple of changes were made to the original code to make it compatible
     * with the `al-foio` theme.
     */
    (function () {
      var progressBar = document.getElementById('progress');
      if (!progressBar) return;

      // The vertical scroll position: pixels hidden above the viewport.
      function getCurrentScrollPosition() {
        return window.pageYOffset || document.documentElement.scrollTop || 0;
      }

      // Full scrollable distance — document height minus viewport height.
      function getDistanceToScroll() {
        var doc = document.documentElement;
        var body = document.body;
        var docHeight = Math.max(body.scrollHeight, doc.scrollHeight, body.offsetHeight, doc.offsetHeight, doc.clientHeight);
        return docHeight - window.innerHeight;
      }

      function initializeProgressElement() {
        /*
         * The body padding-top, progress.top, and .progress-container
         * top are all set in CSS now (with a media-query split at
         * Bootstrap's `sm` breakpoint, matching navbar-expand-sm).
         * The previous version measured the navbar at `load + 50 ms`
         * and assigned inline styles, which on mobile snapped content
         * up ~13 px after first paint (the visible "re-adjustment"
         * during page load). All three values are now correct from
         * first paint, so this function only has to wire up the
         * progress bar's reactive max/value attributes.
         */
        progressBar.setAttribute('max', getDistanceToScroll());
        progressBar.setAttribute('value', getCurrentScrollPosition());
      }

      function getWidthPercentage() {
        return (getCurrentScrollPosition() / getDistanceToScroll()) * 100;
      }

      function resizeProgressBar() {
        progressBar.style.width = getWidthPercentage() + '%';
      }

      function progressBarSetup() {
        if ('max' in document.createElement('progress')) {
          initializeProgressElement();
          document.addEventListener('scroll', function () {
            progressBar.setAttribute('value', getCurrentScrollPosition());
          });
          window.addEventListener('resize', initializeProgressElement);
        } else {
          resizeProgressBar();
          document.addEventListener('scroll', resizeProgressBar);
          window.addEventListener('resize', resizeProgressBar);
        }
      }

      /*
       * Was `load + 50 ms` to let images settle before measuring
       * the navbar — that measurement is gone now (CSS handles
       * the offset), so we can wire up scroll/resize listeners as
       * soon as the DOM is ready. Still wait for `load` for the
       * initial getDistanceToScroll() so document height accounts
       * for any late-arriving content; this just removes the
       * 50 ms artificial delay.
       */
      window.addEventListener('load', progressBarSetup);
    })();
  </script>
{% endif %}
