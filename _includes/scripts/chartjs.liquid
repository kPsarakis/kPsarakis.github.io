{% if page.chart and page.chart.chartjs %}
  <script
    defer
    src="{{ site.third_party_libraries.chartjs.url.js }}"
    integrity="{{ site.third_party_libraries.chartjs.integrity.js }}"
    crossorigin="anonymous"
  ></script>
  <script>
    (function () {
      function renderCharts() {
        if (typeof Chart === 'undefined') return;
        document.querySelectorAll('.language-chartjs').forEach(function (el) {
          var text = el.textContent;
          if (!text) return;
          var canvas = document.createElement('canvas');
          el.textContent = '';
          el.appendChild(canvas);
          var ctx = canvas.getContext('2d');
          if (!ctx) return;
          new Chart(ctx, JSON.parse(text));
          el.setAttribute('data-processed', 'true');
        });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', renderCharts);
      } else {
        renderCharts();
      }
    })();
  </script>
{% endif %}
