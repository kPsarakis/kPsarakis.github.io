{% if site.back_to_top %}
  <!--
    Deferred so the ~2 KiB script download doesn't block render.
    Lighthouse flagged the original load as ~470 ms render-block,
    and after I2/I3 the library's DOMContentLoaded init still cost
    ~223 ms of forced reflow (it injects a <style>, appends a <div>,
    and attaches a scroll listener all at once).

    The button is only useful once the user has scrolled past the
    fold — so we pay nothing until they do. A passive scroll
    listener waits for ~200 px of scroll, then calls addBackToTop()
    and detaches itself. This trades one scroll event for zero cost
    at initial paint.
  -->
  <script
    defer
    src="{{ '/assets/js/vanilla-back-to-top.min.js' | relative_url | bust_file_cache }}"
  ></script>
  <script>
    (function () {
      var initialized = false;
      function init() {
        if (initialized) return;
        // Deferred script may not have parsed yet on very fast
        // scrolls (rare). Re-check on next idle callback.
        if (typeof addBackToTop !== 'function') {
          (window.requestIdleCallback || window.setTimeout)(init, 50);
          return;
        }
        initialized = true;
        window.removeEventListener('scroll', onScroll);
        addBackToTop();
      }
      function onScroll() {
        if (window.scrollY > 200) init();
      }
      window.addEventListener('scroll', onScroll, { passive: true });
    })();
  </script>
{% endif %}
