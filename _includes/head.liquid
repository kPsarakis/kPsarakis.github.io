<!-- Metadata, OpenGraph and Schema.org -->
{% include metadata.liquid %}

<!--
  Best-effort hint to Google Scholar not to index this site. Scholar
  does not expose a distinct user-agent so robots.txt cannot target
  it; `googlebot-scholar` is an undocumented directive cited in the
  community but not officially confirmed by Google. Harmless for
  regular Googlebot (which ignores unknown names) and the only lever
  we have short of stripping Highwire `citation_*` meta tags (which
  this site already doesn't emit).
-->
<meta name="googlebot-scholar" content="noindex">

<!--
  Preconnect to external origins. Google's font hosts were dropped
  when Roboto moved to self-hosted woff2 (see preload + @font-face
  below); cdn.jsdelivr.net is still used by bootstrap-bundle JS and
  a few other libs, so keep that one.
-->
<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>

<!--
  Preload the two FontAwesome faces actually used above the fold
  (social icons etc.). Lighthouse flagged the font fetches as ~464 ms
  on the critical request chain because the browser only discovers
  them after parsing main.css. Preloading pulls them onto the initial
  request wave. `crossorigin` is required even for same-origin font
  preloads — without it the request is re-issued when the CSS
  references arrive. Keep this list tight: each preload is a
  guaranteed download, so adding fonts the page doesn't use wastes
  bandwidth.
-->
<link rel="preload" as="font" type="font/woff2" href="{{ '/assets/webfonts/fa-solid-900.woff2' | relative_url }}" crossorigin>
<link rel="preload" as="font" type="font/woff2" href="{{ '/assets/webfonts/fa-brands-400.woff2' | relative_url }}" crossorigin>
<!--
  Preload Academicons + Scholar-icons woff2. The /about page's
  social row uses both font families heavily (DBLP, ORCID,
  ResearchGate, Google Scholar, Scopus from Academicons; the few
  Scholar-icons codepoints elsewhere). Without preload the chain
  was: HTML → CSS link parsed → font URL discovered → font fetch
  → render. With preload the font is fetched at HTML parse time
  in parallel with everything else, so the icons paint with the
  rest of the page instead of flickering in late.

  Both files were converted from the upstream WOFF/TTF to woff2
  via fonttools (76% / ~70% smaller respectively) and committed
  alongside this change. The @font-face declarations in the icon
  CSS now reference woff2 first, woff as fallback, and use
  font-display: block so we get a brief invisible period rather
  than a tofu-then-icon swap on slow connections.
-->
<link rel="preload" as="font" type="font/woff2" href="{{ '/assets/webfonts/academicons.woff2' | relative_url }}" crossorigin>
<link rel="preload" as="font" type="font/woff2" href="{{ '/assets/webfonts/scholar-icons.woff2' | relative_url }}" crossorigin>
<!--
  Preload Roboto (variable font, Latin subset). Self-hosted so we
  can fetch it at HTML parse time in parallel with the document
  body — usually finishes before first paint, so users see Roboto
  immediately with no FOUT/FOIT swap. The @font-face declaration
  in _mdb-compat.scss uses font-display: optional, so on the rare
  slow connection that misses the 100 ms deadline, the size-
  adjusted Arial fallback is kept for that page load instead of
  swapping mid-paint.

  Latin-Ext is NOT preloaded — most pages on this site use only
  Latin glyphs, and the browser fetches latin-ext on demand when
  a covered codepoint is referenced. Adding it would waste ~29 KiB
  on most page loads.
-->
<link rel="preload" as="font" type="font/woff2" href="{{ '/assets/webfonts/Roboto-latin-VF.woff2' | relative_url }}" crossorigin>

<!--
  Preload LCP image. Split by viewport so phones fetch the 200×284
  variant (~4 KiB) instead of the 423×600 master (~12 KiB); Lighthouse
  flagged the oversized download as ~11 KiB of waste on mobile. The
  <picture>/<img> pair in _layouts/about.liquid uses the same media
  query so the preload matches the chosen source exactly.
-->
{% if page.profile.image %}
  {% assign profile_image_full = page.profile.image | prepend: 'assets/img/' | relative_url | bust_file_cache %}
  {% if page.profile.image_sm %}
    {% assign profile_image_sm = page.profile.image_sm | prepend: 'assets/img/' | relative_url | bust_file_cache %}
    <link rel="preload" as="image" href="{{ profile_image_sm }}" media="(max-width: 575px)" fetchpriority="high">
    <link rel="preload" as="image" href="{{ profile_image_full }}" media="(min-width: 576px)" fetchpriority="high">
  {% else %}
    <link rel="preload" as="image" href="{{ profile_image_full }}" fetchpriority="high">
  {% endif %}
{% endif %}

<!--
  Bootstrap (self-hosted so PurgeCSS can tree-shake the ~96%
  unused rules Lighthouse flagged; upstream CDN shipped the full
  32 KiB compressed every page load)
-->
<link rel="stylesheet" href="{{ '/assets/css/bootstrap.min.css' | relative_url | bust_file_cache }}">

<!-- Bootstrap Table -->
{% if page.pretty_table %}
  <link
    rel="stylesheet"
    href="{{ site.third_party_libraries.bootstrap-table.url.css }}"
    integrity="{{ site.third_party_libraries.bootstrap-table.integrity.css }}"
    crossorigin="anonymous"
  >
{% endif %}

<!--
  Fonts & Icons. Roboto used to be loaded here via Google Fonts
  CSS; now self-hosted (see @font-face in _mdb-compat.scss +
  preload above). Roboto Slab was also requested but unused in
  any rule, dropped.

  Academicons + Scholar-icons CSS were previously loaded async
  via the media="print" / onload trick. That delayed @font-face
  parsing until after first paint, so the icon woff URLs were
  discovered late and icons flickered in visibly on /about. Now
  loaded synchronously: each file is small (academicons ~7.8 KiB,
  scholar-icons ~5 KiB), under brotli ~3 KiB each, well below the
  threshold where async-loading wins. The woff2 fonts are
  preloaded above so they fetch in parallel with the CSS itself.
-->
<link rel="stylesheet" href="{{ '/assets/css/academicons.min.css' | relative_url | bust_file_cache }}">
<link rel="stylesheet" href="{{ '/assets/css/scholar-icons.css' | relative_url | bust_file_cache }}">

<!-- Code Syntax Highlighting -->
<link
  rel="stylesheet"
  href="{{ '/assets/css/jekyll-pygments-themes-github.css' | relative_url | bust_file_cache }}"
  media="print"
  onload="this.media='all'"
  id="highlight_theme_light"
>

<!-- Styles -->

<!-- pseudocode -->
{% if page.pseudocode %}
  <link
    rel="stylesheet"
    href="{{ site.third_party_libraries.pseudocode.url.css }}"
    integrity="{{ site.third_party_libraries.pseudocode.integrity.css }}"
    crossorigin="anonymous"
  >
{% endif %}

{% if site.icon.size <= 4 %}
  <link
    rel="shortcut icon"
    href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>{{ site.icon }}</text></svg>"
  >
{% elsif site.icon != blank %}
  <link rel="shortcut icon" href="{{ site.icon | prepend: '/assets/img/' | relative_url | bust_file_cache}}">
{% endif %}
<link rel="stylesheet" href="{{ '/assets/css/main.css' | relative_url | bust_css_cache }}">
<link rel="canonical" href="{{ page.url | replace:'index.html','' | absolute_url }}">

<!--
  Dark Mode — inlined because theme.js has to run before first paint
  (it sets `data-theme` on <html>) and can't be deferred without a
  FOUC. Lighthouse flagged the external fetch as ~450 ms of render-
  blocking time; the minified body is a few KB, well under the cost
  of an extra round-trip. Source lives in _includes/scripts/theme.js
  so editors still get .js syntax highlighting.
-->
<script>
  {% include scripts/theme.js %}
</script>
{% if site.enable_darkmode %}
  <link
    rel="stylesheet"
    href="{{ '/assets/css/jekyll-pygments-themes-native.css' | relative_url | bust_file_cache }}"
    media="none"
    id="highlight_theme_dark"
  >
  <script>
    initTheme();
  </script>
{% endif %}

<!-- GeoJSON support via Leaflet -->
{% if page.map %}
  <link
    rel="stylesheet"
    href="{{ site.third_party_libraries.leaflet.url.css }}"
    integrity="{{ site.third_party_libraries.leaflet.integrity.css }}"
    crossorigin="anonymous"
  >
{% endif %}

<!-- diff2html -->
{% if page.code_diff %}
  <link
    rel="stylesheet"
    href="{{ site.third_party_libraries.highlightjs.url.css.light }}"
    integrity="{{ site.third_party_libraries.highlightjs.integrity.css.light }}"
    crossorigin="anonymous"
    media="screen and (prefers-color-scheme: light)"
  >
  <link
    rel="stylesheet"
    href="{{ site.third_party_libraries.highlightjs.url.css.dark }}"
    integrity="{{ site.third_party_libraries.highlightjs.integrity.css.dark }}"
    crossorigin="anonymous"
    media="screen and (prefers-color-scheme: dark)"
  >
  <link
    rel="stylesheet"
    href="{{ site.third_party_libraries.diff2html.url.css }}"
    integrity="{{ site.third_party_libraries.diff2html.integrity.css }}"
    crossorigin="anonymous"
  >
{% endif %}

{% if page.images %}
  <!-- Image comparison slider -->
  {% if page.images.compare %}
    <link
      rel="stylesheet"
      href="{{ site.third_party_libraries.img-comparison-slider.url.css }}"
      integrity="{{ site.third_party_libraries.img-comparison-slider.integrity.css }}"
      crossorigin="anonymous"
    >
  {% endif %}
  <!-- Lightbox2 -->
  {% if page.images.lightbox2 %}
    <link
      rel="stylesheet"
      href="{{ site.third_party_libraries.lightbox2.url.css }}"
      integrity="{{ site.third_party_libraries.lightbox2.integrity.css }}"
      crossorigin="anonymous"
    >
  {% endif %}
  <!-- Photoswipe -->
  {% if page.images.photoswipe %}
    <link
      rel="stylesheet"
      href="{{ site.third_party_libraries.photoswipe.url.css }}"
      crossorigin="anonymous"
    >
  {% endif %}
  <!-- Image slider -->
  {% if page.images.slider %}
    <link
      rel="stylesheet"
      href="{{ site.third_party_libraries.swiper.url.css }}"
      integrity="{{ site.third_party_libraries.swiper.integrity.css }}"
      crossorigin="anonymous"
    >
  {% endif %}
  <!-- Spotlight -->
  {% if page.images.spotlight %}
    <link
      rel="stylesheet"
      href="{{ site.third_party_libraries.spotlight.url.css }}"
      integrity="{{ site.third_party_libraries.spotlight.integrity.css }}"
      crossorigin="anonymous"
    >
  {% endif %}
  <!-- Venobox -->
  {% if page.images.venobox %}
    <link
      rel="stylesheet"
      href="{{ site.third_party_libraries.venobox.url.css }}"
      integrity="{{ site.third_party_libraries.venobox.integrity.css }}"
      crossorigin="anonymous"
    >
  {% endif %}
{% endif %}

{% if page.tikzjax %}
  <link rel="stylesheet" type="text/css" href="https://tikzjax.com/v1/fonts.css">
{% endif %}
